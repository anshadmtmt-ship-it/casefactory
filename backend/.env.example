# Django Base Configurations
DEBUG=False
DJANGO_SECRET_KEY=generate-a-secure-random-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# PostgreSQL Database Configurations (or your target DB)
DB_NAME=casefactory
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_HOST=localhost
DB_PORT=5432

# Transactional Email Settings (SMTP Provider)
EMAIL_PROVIDER=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=casefactorycpy@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_TIMEOUT=30

# Alternative Email Providers (Uncomment if using Resend or SendGrid)
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_your_api_key

# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.your_api_key
